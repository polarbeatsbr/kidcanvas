{
  "functions": {
    "api/server.js": {
      "includeFiles": "{index.html,creation_dates.json,pintai-biblioteca/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/politica-de-privacidade",
      "destination": "/index.html"
    },
    {
      "source": "/categorias",
      "destination": "/index.html"
    },
    {
      "source": "/top50",
      "destination": "/index.html"
    },
    {
      "source": "/categoria/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:category/:drawing",
      "destination": "/index.html"
    }
  ]
}
