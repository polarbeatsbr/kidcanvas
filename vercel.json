{
  "functions": {
    "api/server.js": {
      "includeFiles": "{index.html,admin.html,admin-expeditions.html,historia.html,creation_dates.json,drawings.json,events.json,api/cards_catalog.json,api/certificates_catalog.json,public_paintings.json,ratings.json}",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/t",
      "destination": "/painel-teste.html"
    },
    {
      "source": "/t/",
      "destination": "/painel-teste.html"
    },
    {
      "source": "/pintar-online",
      "destination": "/index.html"
    },
    {
      "source": "/cientista-maluco",
      "destination": "/index.html"
    },
    {
      "source": "/cientista-maluco-mobile",
      "destination": "/cientista-maluco-mobile.html"
    },
    {
      "source": "/js/:file",
      "destination": "/js/:file"
    },
    {
      "source": "/stickers/:file*",
      "destination": "/stickers/:file*"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin-expeditions",
      "destination": "/admin-expeditions.html"
    },
    {
      "source": "/reportar-bug",
      "destination": "/index.html"
    },
    {
      "source": "/historias-magicas",
      "destination": "/index.html"
    },
    {
      "source": "/historia",
      "destination": "/index.html"
    },
    {
      "source": "/historias-exemplo",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/politica-de-privacidade",
      "destination": "/index.html"
    },
    {
      "source": "/categorias",
      "destination": "/index.html"
    },
    {
      "source": "/top50",
      "destination": "/index.html"
    },
    {
      "source": "/planos",
      "destination": "/index.html"
    },
    {
      "source": "/hall-da-fama",
      "destination": "/index.html"
    },
    {
      "source": "/gerar-desenho",
      "destination": "/index.html"
    },
    {
      "source": "/pintura-livre",
      "destination": "/index.html"
    },
    {
      "source": "/conquistas",
      "destination": "/index.html"
    },
    {
      "source": "/perfil",
      "destination": "/index.html"
    },
    {
      "source": "/categoria/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/:category([^/.]+)/:drawing([^/.]+)",
      "destination": "/index.html"
    }
  ]
}
